{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-public-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "chatrooms-route": {
        "ClusterId": "chatroom-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        }
      },
      "messages-route": {
        "ClusterId": "message-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "hub-route": {
        "ClusterId": "hub-cluster",
        "Match": {
          "Path": "/chatHub/{**catch-all}"
        }
      },
      "media-route": {
        "ClusterId": "media-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-dest": {
            "Address": "https://auth-service-kt3x.onrender.com/"
          }
        }
      },
      "message-cluster": {
        "Destinations": {
          "message-dest": {
            "Address": "https://message-service-av0h.onrender.com/"
          }
        }
      },
      "chatroom-cluster": {
        "Destinations": {
          "chatroom-dest": {
            "Address": "https://chatroom-service-av0h.onrender.com/"
          }
        }
      },
      "hub-cluster": {
        "Destinations": {
          "hub-dest": {
            "Address": "https://hub-service-av0h.onrender.com/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-dest": {
            "Address": "https://notification-service-av0h.onrender.com/"
          }
        }
      },
      "media-cluster": {
        "Destinations": {
          "media-dest": {
            "Address": "https://media-service-av0h.onrender.com/"
          }
        }
      }
    }
  }
}
