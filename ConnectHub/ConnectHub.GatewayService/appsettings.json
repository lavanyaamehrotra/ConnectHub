{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "JWT": {
    "Secret": "This-Is-My-Super-Secret-Key-For-JWT-At-Least-32-Characters-Long-ChangeThis!"
  },

  // ============================================================
  // YARP REVERSE PROXY CONFIGURATION
  //
  // Routes  — match incoming requests by path/method/headers
  // Clusters — define the backend service(s) to forward to
  //
  // AuthorizationPolicy:
  //   "default"      = requires valid JWT (uses [Authorize])
  //   "anonymous"    = no JWT needed (login / register / public)
  // ============================================================
  "ReverseProxy": {

    "Routes": {

      // ── AUTH SERVICE ──────────────────────────────────────────
      // Public routes (no JWT needed)
      "auth-public-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },

      // Protected user routes (JWT required)
      "users-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },

      // ── MESSAGE SERVICE ───────────────────────────────────────
      "messages-route": {
        "ClusterId": "message-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      },

      // ── CHATROOM SERVICE ──────────────────────────────────────
      "chatrooms-route": {
        "ClusterId": "chatroom-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/chatrooms/{**catch-all}"
        }
      },

      // ── HUB SERVICE — SignalR WebSocket ───────────────────────
      // WebSocket upgrade must NOT be intercepted — pass through as-is
      "signalr-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },

      // Presence REST API
      "presence-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/presence/{**catch-all}"
        }
      },

      // Internal badge-push endpoint (called by NotificationService)
      "notify-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/notify/{**catch-all}"
        }
      },

      // ── NOTIFICATION SERVICE ──────────────────────────────────
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },

      // ── MEDIA SERVICE ─────────────────────────────────────────
      "media-route": {
        "ClusterId": "media-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        }
      }
    },

    "Clusters": {

      // AuthService — port 5000
      "auth-cluster": {
        "Destinations": {
          "auth-dest": {
            "Address": "http://localhost:5000/"
          }
        }
      },

      // MessageService — port 5003
      "message-cluster": {
        "Destinations": {
          "message-dest": {
            "Address": "http://localhost:5003/"
          }
        }
      },

      // ChatRoomService — port 5005 (dev) / 5004 (Docker)
      "chatroom-cluster": {
        "Destinations": {
          "chatroom-dest": {
            "Address": "http://localhost:5005/"
          }
        }
      },

      // HubService (SignalR + Presence) — port 5006
      "hub-cluster": {
        "Destinations": {
          "hub-dest": {
            "Address": "http://localhost:5006/"
          }
        }
      },

      // NotificationService — port 5007
      "notification-cluster": {
        "Destinations": {
          "notification-dest": {
            "Address": "http://localhost:5007/"
          }
        }
      },

      // MediaService — port 5008
      "media-cluster": {
        "Destinations": {
          "media-dest": {
            "Address": "http://localhost:5008/"
          }
        }
      }
    }
  }
}
