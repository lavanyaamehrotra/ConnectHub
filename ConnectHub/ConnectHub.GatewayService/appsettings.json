{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",

  "JWT": {
    "Secret": "This-Is-My-Super-Secret-Key-For-JWT-At-Least-32-Characters-Long-ChangeThis!"
  },

  "ReverseProxy": {

    "Routes": {

      "auth-public-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },

      "users-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        }
      },

      "messages-route": {
        "ClusterId": "message-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/messages/{**catch-all}"
        }
      },

      "chatrooms-route": {
        "ClusterId": "chatroom-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/rooms/{**catch-all}"
        }
      },

      "signalr-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/hubs/{**catch-all}"
        }
      },

      "presence-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/presence/{**catch-all}"
        }
      },

      "notify-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/notify/{**catch-all}"
        }
      },

      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },

      "media-route": {
        "ClusterId": "media-cluster",
        "AuthorizationPolicy": "default",
        "CorsPolicy": "AllowFrontends",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-dest": {
            "Address": "https://auth-service-kt3x.onrender.com/"
          }
        }
      },
      "message-cluster": {
        "Destinations": {
          "message-dest": {
            "Address": "https://message-service-hjaw.onrender.com/"
          }
        }
      },
      "chatroom-cluster": {
        "Destinations": {
          "chatroom-dest": {
            "Address": "https://chatroom-service-hjaw.onrender.com/"
          }
        }
      },
      "hub-cluster": {
        "Destinations": {
          "hub-dest": {
            "Address": "https://hub-service-hjaw.onrender.com/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-dest": {
            "Address": "https://notification-service-hjaw.onrender.com/"
          }
        }
      },
      "media-cluster": {
        "Destinations": {
          "media-dest": {
            "Address": "http://localhost:5008/"
          }
        }
      }
    }
  }
}
