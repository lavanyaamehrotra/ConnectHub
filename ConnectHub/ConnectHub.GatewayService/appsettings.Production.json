{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "auth-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
