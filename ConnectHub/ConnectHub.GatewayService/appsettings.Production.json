{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "JWT": {
    "Secret": "This-Is-My-Super-Secret-Key-For-JWT-At-Least-32-Characters-Long-ChangeThis!"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-public-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "users-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/user/{**catch-all}" }
      },
      "chatroom-public-route": {
        "ClusterId": "chatroom-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/rooms/public" }
      },
      "chatrooms-route": {
        "ClusterId": "chatroom-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/rooms/{**catch-all}" }
      },
      "messages-route": {
        "ClusterId": "message-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/messages/{**catch-all}" }
      },
      "signalr-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/hubs/chat/{**catch-all}" }
      },
      "presence-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/presence/{**catch-all}" }
      },
      "notify-route": {
        "ClusterId": "hub-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/notify/{**catch-all}" }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "media-route": {
        "ClusterId": "media-cluster",
        "AuthorizationPolicy": "anonymous",
        "CorsPolicy": "AllowFrontends",
        "Match": { "Path": "/api/media/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "HttpRequest": { "ActivityTimeout": "00:05:00" },
        "Destinations": {
          "auth-dest": { "Address": "https://auth-service-kt3x.onrender.com/" }
        }
      },
      "message-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "HttpRequest": { "ActivityTimeout": "00:05:00" },
        "Destinations": {
          "message-dest": { "Address": "https://message-service-p29m.onrender.com/" }
        }
      },
      "chatroom-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "HttpRequest": { "ActivityTimeout": "00:05:00" },
        "Destinations": {
          "chatroom-dest": { "Address": "https://chatroom-service-av9h.onrender.com/" }
        }
      },
      "hub-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "HttpRequest": { "ActivityTimeout": "00:05:00" },
        "Destinations": {
          "hub-dest": { "Address": "https://hub-service-4xti.onrender.com/" }
        }
      },
      "notification-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "HttpRequest": { "ActivityTimeout": "00:05:00" },
        "Destinations": {
          "notification-dest": { "Address": "https://notification-service-gduz.onrender.com/" }
        }
      },
      "media-cluster": {
        "HttpClient": { "DangerousAcceptAnyServerCertificate": true },
        "HttpRequest": { "ActivityTimeout": "00:05:00" },
        "Destinations": {
          "media-dest": { "Address": "https://media-service-os9l.onrender.com/" }
        }
      }
    }
  }
}
