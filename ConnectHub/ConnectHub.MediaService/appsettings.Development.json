{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "ConnectHub": "Debug"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=ConnectHubMediaDb;Username=postgres;Password=YOUR_DATABASE_PASSWORD"
  },
  "JWT": {
    "Secret": "YOUR_SUPER_SECRET_JWT_KEY_HERE"
  },
  "Azure": {
    "BlobConnectionString": "UseDevelopmentStorage=true",
    "MaxFileSizeMb": "50",
    "AllowedContentTypes": "image/,video/,application/pdf,text/",
    "FileExpiryDays": "0"
  }
}
